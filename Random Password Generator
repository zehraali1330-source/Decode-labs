def generate_password(length=12, use_uppercase=True, use_lowercase=True,

                        use_digits=True, use_special=True):

    # Build the character pool based on user preferences
    char_pool = ""

    if use_uppercase:
        char_pool += string.ascii_uppercase  # "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    if use_lowercase:
        char_pool += string.ascii_lowercase  # "abcdefghijklmnopqrstuvwxyz"
    if use_digits:
        char_pool += string.digits           # "0123456789"
    if use_special:
        char_pool += string.punctuation      # "!"#$%&'()*+,-./:;<=>?@[\]^_`{|}~"

    # --- VALIDATION ---
    if not char_pool:
        raise ValueError("❌ Trash config. You disabled ALL character types. Pick at least one.")

    if length < 1:
        raise ValueError("❌ Trash input. Password length must be at least 1.")

    if length < 8:
        print("⚠️  Warning: Passwords under 8 characters are WEAK. Consider 12+ for security.")

    # --- GENERATION ---
    # Use random.choices for efficiency (allows repetition, which is what we want)
    password = ''.join(random.choices(char_pool, k=length))

    return password


def interactive_password_generator():
    """
    Interactive CLI version that asks the user for preferences.
    """
    print("=" * 55)
    print("🔐 RANDOM PASSWORD GENERATOR")
    print("=" * 55)

    # Get password length
    while True:
        try:
            length_input = input("Enter password length (recommended: 12-16): ").strip()
            length = int(length_input)
            if length < 1:
                print("❌ Trash input. Length must be at least 1.")
                continue
            break
        except ValueError:
            print("❌ Trash input. Enter a NUMBER, not whatever that was.")

    # Get character type preferences
    print("--- Character Types ---")
    use_upper = input("Include uppercase letters (A-Z)? [y/n]: ").strip().lower() == 'y'
    use_lower = input("Include lowercase letters (a-z)? [y/n]: ").strip().lower() == 'y'
    use_digits = input("Include digits (0-9)? [y/n]: ").strip().lower() == 'y'
    use_special = input("Include special characters (!@#$% etc.)? [y/n]: ").strip().lower() == 'y'

    # Generate and display
    try:
        password = generate_password(length, use_upper, use_lower, use_digits, use_special)

        print("" + "=" * 55)
        print("🎉 YOUR GENERATED PASSWORD:")
        print("=" * 55)
        print(f"   {password}")
        print("=" * 55)

        # Security analysis
        analyze_password_strength(password)

    except ValueError as e:
        print(e)


def analyze_password_strength(password):
    """
    Analyzes and reports the strength of the generated password.
    """
    length = len(password)
    has_upper = any(c.isupper() for c in password)
    has_lower = any(c.islower() for c in password)
    has_digit = any(c.isdigit() for c in password)
    has_special = any(c in string.punctuation for c in password)

    char_types = sum([has_upper, has_lower, has_digit, has_special])

    print("PASSWORD ANALYSIS:")
    print(f"   Length:           {length} characters")
    print(f"   Character types:  {char_types}/4 (upper, lower, digits, special)")

    # Strength rating
    if length >= 16 and char_types == 4:
        strength = "💪 STRONG - Good job, this is actually decent."
    elif length >= 12 and char_types >= 3:
        strength = "😐 MODERATE - Acceptable for low-risk accounts."
    elif length >= 8 and char_types >= 2:
        strength = "😬 WEAK - Don't use this for anything important."
    else:
        strength = "🗑️ TRASH - This password is a joke. Try again."

    print(f"   Strength:         {strength}")

    # Entropy estimate (rough)
    pool_size = 0
    if has_upper: pool_size += 26
    if has_lower: pool_size += 26
    if has_digit: pool_size += 10
    if has_special: pool_size += len(string.punctuation)

    if pool_size > 0:
        import math
        entropy = length * math.log2(pool_size)
        print(f"   Estimated entropy: {entropy:.1f} bits")
        if entropy < 40:
            print("   ⚠️  Entropy is LOW. Easily crackable.")
        elif entropy < 60:
            print("   ⚠️  Entropy is MODERATE. Fine for casual use.")
        else:
            print("   ✅ Entropy is GOOD. Resistant to brute force.")


# Run it
if __name__ == "__main__":
    interactive_password_generator()
